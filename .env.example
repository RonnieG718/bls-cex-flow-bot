# === Bitquery (your existing API key) ===
BITQUERY_API_KEY=

# === Supabase (BLS project: wvmlotamldkwgcyrwgxb) ===
SUPABASE_URL=https://wvmlotamldkwgcyrwgxb.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# === Discord webhook for CEX flow alerts ===
# Create a new channel #cex-flow-alerts and webhook for it
DISCORD_WEBHOOK_CEX_FLOW=

# === Etherscan free tier (optional, for weekly address auto-refresh) ===
# Get free key at https://etherscan.io/apis
ETHERSCAN_API_KEY=

# === Alert thresholds ===
# Trigger alert if |net_flow| in any (exchange, asset) pair exceeds this in 1h
ALERT_THRESHOLD_USD=5000000

# Or if |net_flow| exceeds this percent of the (exchange, asset)'s 7-day daily average
ALERT_THRESHOLD_PCT_DAILY_AVG=20

# === Optional ===
# Railway sets PORT automatically. For local dev only.
PORT=8080
